{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/Dockerfile",
    "buildEnvironment": "v3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "sh ./start.sh",
    "sleepApplication": false,
    "useLegacyStacker": false
  }
}
